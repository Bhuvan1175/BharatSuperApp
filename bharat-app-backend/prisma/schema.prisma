generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  phoneNumber          String?   @unique
  email                String?   @unique
  name                 String?
  username             String?   @unique
  bio                  String?
  profileImage         String?
  profileImagePublicId String?
  isVerified           Boolean   @default(false)
  refreshToken         String?
  lastLoginAt          DateTime?
  lastLoginDevice      String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // ---- RBAC (added; all optional/defaulted → additive, non-breaking) ----
  isActive     Boolean     @default(true)
  roleId       String?
  role         Role?       @relation(fields: [roleId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // Module entries this user authored (Water updates, etc.). Optional relation.
  listings Listing[] @relation("ListingCreatedBy")

  @@index([roleId])
  @@index([departmentId])
}

/// A role a user can hold. Data-driven so a Super Admin can create new roles at
/// runtime. `permissions` are strings like "medicine:manage"; "*" = all.
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String?
  permissions String[] @default([])
  // System roles are seeded and must not be deleted via the admin API.
  isSystem    Boolean  @default(false)
  users       User[]
  // Departments for which this role is the default manager role.
  defaultForDepartments Department[] @relation("DepartmentDefaultRole")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// A department that owns one app module. `moduleKey` (e.g. "medicine") ties the
/// department to a module and matches the frontend module keys. `defaultRole`
/// is the manager role auto-assigned when a user is put in this department.
model Department {
  id            String   @id @default(cuid())
  name          String   @unique
  label         String?
  moduleKey     String   @unique
  isActive      Boolean  @default(true)
  defaultRoleId String?
  defaultRole   Role?    @relation("DepartmentDefaultRole", fields: [defaultRoleId], references: [id])
  users         User[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([defaultRoleId])
}

/// ---- Location hierarchy: State → District → City → Locality ----
/// Shared reference data used by every module. Cascade deletes flow downward,
/// so removing a State cleans up its Districts → Cities → Localities.

model State {
  id        String     @id @default(cuid())
  name      String     @unique
  districts District[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model District {
  id        String   @id @default(cuid())
  name      String
  stateId   String
  state     State    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stateId, name])
  @@index([stateId])
}

model City {
  id         String     @id @default(cuid())
  name       String
  districtId String
  district   District   @relation(fields: [districtId], references: [id], onDelete: Cascade)
  localities Locality[]
  listings   Listing[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([districtId, name])
  @@index([districtId])
}

model Locality {
  id        String    @id @default(cuid())
  name      String
  pincode   String?
  latitude  Float?
  longitude Float?
  cityId    String
  city      City      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  listings  Listing[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([cityId, name])
  @@index([cityId])
}

/// A generic module entry — one flexible table serving every department module.
/// `moduleKey` ties it to a Department/module (e.g. "water"). `type` describes
/// the kind of entry ("update", "alert", "listing", …). `data` holds any
/// module-specific extras as JSON so new departments need no schema change.
model Listing {
  id          String    @id @default(cuid())
  moduleKey   String
  type        String    @default("update")
  title       String
  body        String?
  status      String    @default("active") // active | scheduled | archived | expired
  scheduledAt DateTime?
  expiresAt   DateTime?
  data        Json?

  cityId     String?
  city       City?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  localityId String?
  locality   Locality? @relation(fields: [localityId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?    @relation("ListingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moduleKey])
  @@index([cityId])
  @@index([localityId])
  @@index([status])
}
